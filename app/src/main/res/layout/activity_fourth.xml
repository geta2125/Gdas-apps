<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F4F6">

    <!-- CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:backgroundTint="#F3E5F5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnKembali"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ISI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnShowSnackbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tampilkan Snackbar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7986CB"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnShowAlertDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tampilkan AlertDialog"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4DB6AC"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tombol 1"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B0BEC5"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- BUTTON KEMBALI -->
    <Button
        android:id="@+id/btnKembali"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Kembali"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F48FB1"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>