<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF4FF"
    tools:context=".Message.tutorial.Tutorial1Fragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgTutorial"
            android:layout_width="398dp"
            android:layout_height="328dp"
            android:layout_marginTop="40dp"
            android:contentDescription="Ilustrasi Pesan"
            android:scaleType="fitCenter"
            android:src="@drawable/img" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Selamat Datang!"
            android:textColor="#1E3A5F"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:text="Nikmati kemudahan mengakses berbagai informasi dan layanan desa dalam satu aplikasi. SiPAWA membantu masyarakat mendapatkan layanan yang lebih cepat, mudah, dan transparan."
            android:textColor="#5F6B7A"
            android:textSize="16sp"/>

    </LinearLayout>

</ScrollView>