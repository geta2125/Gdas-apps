<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F4F6"
    tools:context=".Home.HomeFragment">

    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:fontFamily="sans-serif-black"
        android:text="Belajar Mobile itu Asyik!!"
        android:textColor="@android:color/black"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="#F2D8E2"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:useDefaultMargins="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToSecond"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="6dp"
                    android:text="Pertemuan 2"
                    android:textAllCaps="false"
                    app:backgroundTint="#EC7FA9"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToThird"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="6dp"
                    android:text="Pertemuan 3"
                    android:textAllCaps="false"
                    app:backgroundTint="#EC7FA9"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToFourth"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="6dp"
                    android:text="Pertemuan 4"
                    android:textAllCaps="false"
                    app:backgroundTint="#EC7FA9"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToFifth"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="6dp"
                    android:text="Pertemuan 5"
                    android:textAllCaps="false"
                    app:backgroundTint="#EC7FA9"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToSeven"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="6dp"
                    android:text="Pertemuan 7"
                    android:textAllCaps="false"
                    app:backgroundTint="#EC7FA9"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToNinth"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="6dp"
                    android:text="Pertemuan 9"
                    android:textAllCaps="false"
                    app:backgroundTint="#EC7FA9"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1" />

            </androidx.gridlayout.widget.GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#F0F0F0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="#E85D75"
                app:cornerRadius="16dp"
                app:strokeColor="#E85D75"
                app:strokeWidth="2dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>