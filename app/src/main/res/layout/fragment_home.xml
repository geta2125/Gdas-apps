<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F4F6"
    tools:context=".Home.HomeFragment">

    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Selamat Datang"
        android:textColor="@android:color/black"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMenu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#F2D8E2"
        app:strokeWidth="1dp">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        </androidx.core.widget.NestedScrollView>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="112dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Daftar Pertemuan"
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.gridlayout.widget.GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:columnCount="3">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToSecond"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_margin="6dp"
                android:text="Pertemuan 2"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#F48FB1"
                app:cornerRadius="14dp"
                app:layout_columnWeight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToThird"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_margin="6dp"
                android:text="Pertemuan 3"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#F48FB1"
                app:cornerRadius="14dp"
                app:layout_columnWeight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToFourth"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_margin="6dp"
                android:text="Pertemuan 4"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#F48FB1"
                app:cornerRadius="14dp"
                app:layout_columnWeight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToFifth"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_margin="6dp"
                android:text="Pertemuan 5"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#F48FB1"
                app:cornerRadius="14dp"
                app:layout_columnWeight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToSeven"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_margin="6dp"
                android:text="Pertemuan 7"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#F48FB1"
                app:cornerRadius="14dp"
                app:layout_columnWeight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToNinth"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_margin="6dp"
                android:text="Pertemuan 9"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#F48FB1"
                app:cornerRadius="14dp"
                app:layout_columnWeight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToTenth"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_margin="6dp"
                android:text="Pertemuan 10"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#F48FB1"
                app:cornerRadius="14dp"
                app:layout_columnWeight="1" />

        </androidx.gridlayout.widget.GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:text="Galeri Aktivitas"
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/tools_list_item" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#EAEAEA" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="#E85D75"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="#E85D75"
            app:strokeWidth="1.5dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>