<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F4F6"
    tools:context=".Home.HomeFragment">

    <!-- Header -->
    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Judul -->

    <!-- Card Utama -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="Selamat Datang 👋"
        android:textColor="#121212"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMenu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="130dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeColor="#F2D8E2"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp">

                <!-- Daftar Pertemuan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Pertemuan"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <androidx.gridlayout.widget.GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:columnCount="3">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToSecond"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_margin="5dp"
                        android:text="P2"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E88AA4"
                        app:cornerRadius="16dp"
                        app:layout_columnWeight="1"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToThird"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_margin="5dp"
                        android:text="P3"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E88AA4"
                        app:cornerRadius="16dp"
                        app:layout_columnWeight="1"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToFourth"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_margin="5dp"
                        android:text="P4"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E88AA4"
                        app:cornerRadius="16dp"
                        app:layout_columnWeight="1"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToFifth"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_margin="5dp"
                        android:text="P5"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E88AA4"
                        app:cornerRadius="16dp"
                        app:layout_columnWeight="1"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToSeven"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_margin="5dp"
                        android:text="P7"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E88AA4"
                        app:cornerRadius="16dp"
                        app:layout_columnWeight="1"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToNinth"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_margin="5dp"
                        android:text="P9"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E88AA4"
                        app:cornerRadius="16dp"
                        app:layout_columnWeight="1"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToTenth"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_margin="5dp"
                        android:text="P10"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E88AA4"
                        app:cornerRadius="16dp"
                        app:layout_columnWeight="1"/>

                </androidx.gridlayout.widget.GridLayout>

                <!-- Galeri -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Galeri Aktivitas"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvGallery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/tools_list_item" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#EEEEEE"/>

                <!-- Logout -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Logout"
                    android:textAllCaps="false"
                    android:textColor="#E85D75"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:strokeColor="#E85D75"
                    app:strokeWidth="1.5dp"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>