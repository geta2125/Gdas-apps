<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDE7F3"
    tools:context=".pertemuan_2.SecondActivity">

    <androidx.cardview.widget.CardView
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:padding="10dp"
        card_view:cardCornerRadius="25dp"
        card_view:cardElevation="12dp"
        card_view:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="25dp"
            android:gravity="center">

            <!-- Judul -->
            <TextView
                android:id="@+id/textNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome !"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#5D4A66"
                android:layout_marginBottom="25dp"/>

            <!-- Input Nama -->
            <EditText
                android:id="@+id/inputNama"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Geta Dewi Artika Sari"
                android:textColor="#4A4A4A"
                android:textColorHint="#9C8CA5"
                android:backgroundTint="#CDB4DB"
                android:padding="14dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="25dp"/>

            <!-- Tombol -->
            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Submit"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B8C0FF"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>