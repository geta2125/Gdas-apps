<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDCCB8"
    tools:context=".Message.tutorial.Tutorial3Fragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgTutorial"
            android:layout_width="411dp"
            android:layout_height="302dp"
            android:layout_marginTop="40dp"
            android:contentDescription="Ilustrasi Tutorial"
            android:scaleType="fitCenter"
            android:src="@drawable/img" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Mari Kita Mulai!"
            android:textAlignment="center"
            android:textColor="#8B4513"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:text="Semua sudah siap. Jelajahi berbagai fitur yang tersedia dan nikmati pengalaman penggunaan aplikasi yang lebih mudah, cepat, dan nyaman bersama GDAS Apps."
            android:textColor="#6D4C41"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>