<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFEBEB"
    tools:context=".Message.tutorial.Tutorial2Fragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgTutorial"
            android:layout_width="389dp"
            android:layout_height="304dp"
            android:layout_marginTop="40dp"
            android:contentDescription="Ilustrasi Pesan"
            android:scaleType="fitCenter"
            android:src="@drawable/img" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Temukan Fitur Menarik"
            android:textAlignment="center"
            android:textColor="#C85A6A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:text="Jelajahi berbagai fitur yang tersedia di GDAS Apps untuk membantu aktivitas Anda menjadi lebih mudah, cepat, dan efisien. Semua kebutuhan Anda dapat diakses dalam satu aplikasi."
            android:textColor="#7A6A6A"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>